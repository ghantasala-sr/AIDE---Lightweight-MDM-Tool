# Google Cloud Platform Credentials
# ---------------------------------
# 1. Generate a Service Account Key in the GCP Console
# 2. Download the JSON file to your local machine (DO NOT commit it to Git)
# 3. Set the absolute path to the JSON file in the variable below

GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your/gcp-service-account-key.json

# LLM Configuration
# -----------------
# Add any API keys needed for the AI capabilities
# CLAUDE_API_KEY=your_anthropic_api_key
# OPENAI_API_KEY=your_openai_api_key

# Database Configuration
# ----------------------
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASS=password
# DB_NAME=aide_db
